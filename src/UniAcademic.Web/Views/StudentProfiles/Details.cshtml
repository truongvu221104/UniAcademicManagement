@model UniAcademic.Application.Models.StudentProfiles.StudentProfileModel

@{
    ViewData["Title"] = "Student Profile Details";
}

<h1 class="h3 mb-3">Student Profile Details</h1>

<dl class="row">
    <dt class="col-sm-3">Student Code</dt>
    <dd class="col-sm-9">@Model.StudentCode</dd>

    <dt class="col-sm-3">Full Name</dt>
    <dd class="col-sm-9">@Model.FullName</dd>

    <dt class="col-sm-3">Student Class</dt>
    <dd class="col-sm-9">@Model.StudentClassCode - @Model.StudentClassName</dd>

    <dt class="col-sm-3">Email</dt>
    <dd class="col-sm-9">@Model.Email</dd>

    <dt class="col-sm-3">Phone</dt>
    <dd class="col-sm-9">@Model.Phone</dd>

    <dt class="col-sm-3">Date of Birth</dt>
    <dd class="col-sm-9">@Model.DateOfBirth?.ToString("yyyy-MM-dd")</dd>

    <dt class="col-sm-3">Gender</dt>
    <dd class="col-sm-9">@Model.Gender</dd>

    <dt class="col-sm-3">Address</dt>
    <dd class="col-sm-9">@Model.Address</dd>

    <dt class="col-sm-3">Status</dt>
    <dd class="col-sm-9">@Model.Status</dd>

    <dt class="col-sm-3">Note</dt>
    <dd class="col-sm-9">@Model.Note</dd>
</dl>

<a asp-action="Edit" asp-route-id="@Model.Id" class="btn btn-primary">Edit</a>
<a asp-action="Index" class="btn btn-secondary">Back</a>
