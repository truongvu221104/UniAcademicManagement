<!DOCTYPE html>
@inject UniAcademic.Application.Abstractions.Auth.ICurrentStudentContext CurrentStudentContext
@inject UniAcademic.Application.Abstractions.Auth.ICurrentLecturerContext CurrentLecturerContext
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - UniAcademic.Web</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/UniAcademic.Web.styles.css" asp-append-version="true" />
</head>
<body>
    <header>
        <nav class="navbar navbar-expand-sm navbar-toggleable-sm navbar-light bg-white border-bottom box-shadow mb-3">
            <div class="container-fluid">
                <a class="navbar-brand" asp-area="" asp-controller="Home" asp-action="Index">UniAcademic.Web</a>
                <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target=".navbar-collapse" aria-controls="navbarSupportedContent"
                        aria-expanded="false" aria-label="Toggle navigation">
                    <span class="navbar-toggler-icon"></span>
                </button>
                <div class="navbar-collapse collapse d-sm-inline-flex justify-content-between">
                    @{
                        var hasStudentPortal = User.Identity?.IsAuthenticated == true
                            && await CurrentStudentContext.GetStudentProfileIdAsync() is not null;
                        var hasLecturerPortal = User.Identity?.IsAuthenticated == true
                            && await CurrentLecturerContext.GetLecturerProfileIdAsync() is not null;
                    }
                    <ul class="navbar-nav flex-grow-1">
                        <li class="nav-item">
                            <a class="nav-link text-dark" asp-area="" asp-controller="Home" asp-action="Index">Home</a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link text-dark" asp-area="" asp-controller="Home" asp-action="Privacy">Privacy</a>
                        </li>
                        @if (User.Identity?.IsAuthenticated == true)
                        {
                            <li class="nav-item">
                                <a class="nav-link text-dark" asp-controller="Faculties" asp-action="Index">Faculties</a>
                            </li>
                            <li class="nav-item">
                                <a class="nav-link text-dark" asp-controller="StudentClasses" asp-action="Index">Student Classes</a>
                            </li>
                            <li class="nav-item">
                                <a class="nav-link text-dark" asp-controller="Courses" asp-action="Index">Courses</a>
                            </li>
                            <li class="nav-item">
                                <a class="nav-link text-dark" asp-controller="Semesters" asp-action="Index">Semesters</a>
                            </li>
                            <li class="nav-item">
                                <a class="nav-link text-dark" asp-controller="CourseOfferings" asp-action="Index">Course Offerings</a>
                            </li>
                            <li class="nav-item">
                                <a class="nav-link text-dark" asp-controller="StudentProfiles" asp-action="Index">Student Profiles</a>
                            </li>
                            <li class="nav-item">
                                <a class="nav-link text-dark" asp-controller="Enrollments" asp-action="Index">Enrollments</a>
                            </li>
                            <li class="nav-item">
                                <a class="nav-link text-dark" asp-controller="Attendance" asp-action="Index">Attendance</a>
                            </li>
                            <li class="nav-item">
                                <a class="nav-link text-dark" asp-controller="Grades" asp-action="Index">Grades</a>
                            </li>
                            <li class="nav-item">
                                <a class="nav-link text-dark" asp-controller="GradeResults" asp-action="Index">Grade Results</a>
                            </li>
                            <li class="nav-item">
                                <a class="nav-link text-dark" asp-controller="LecturerProfiles" asp-action="Index">Lecturer Profiles</a>
                            </li>
                            <li class="nav-item">
                                <a class="nav-link text-dark" asp-controller="LecturerAssignments" asp-action="Index">Lecturer Assignments</a>
                            </li>
                            <li class="nav-item">
                                <a class="nav-link text-dark" asp-controller="CourseMaterials" asp-action="Index">Course Materials</a>
                            </li>
                            @if (hasStudentPortal)
                            {
                                <li class="nav-item">
                                    <a class="nav-link text-dark" asp-area="Student" asp-controller="StudentCourseOfferings" asp-action="Index">My Courses</a>
                                </li>
                                <li class="nav-item">
                                    <a class="nav-link text-dark" asp-area="Student" asp-controller="StudentAttendance" asp-action="Index">My Attendance</a>
                                </li>
                                <li class="nav-item">
                                    <a class="nav-link text-dark" asp-area="Student" asp-controller="StudentGrades" asp-action="Index">My Grades</a>
                                </li>
                                <li class="nav-item">
                                    <a class="nav-link text-dark" asp-area="Student" asp-controller="StudentGradeResults" asp-action="Index">My Results</a>
                                </li>
                                <li class="nav-item">
                                    <a class="nav-link text-dark" asp-area="Student" asp-controller="StudentMaterials" asp-action="Index">My Materials</a>
                                </li>
                            }
                            @if (hasLecturerPortal)
                            {
                                <li class="nav-item">
                                    <a class="nav-link text-dark" asp-area="Lecturer" asp-controller="LecturerOfferings" asp-action="Index">My Teaching</a>
                                </li>
                                <li class="nav-item">
                                    <a class="nav-link text-dark" asp-area="Lecturer" asp-controller="LecturerAttendance" asp-action="Index">Teaching Attendance</a>
                                </li>
                                <li class="nav-item">
                                    <a class="nav-link text-dark" asp-area="Lecturer" asp-controller="LecturerGrades" asp-action="Index">Teaching Grades</a>
                                </li>
                                <li class="nav-item">
                                    <a class="nav-link text-dark" asp-area="Lecturer" asp-controller="LecturerMaterials" asp-action="Index">Teaching Materials</a>
                                </li>
                                <li class="nav-item">
                                    <a class="nav-link text-dark" asp-area="Lecturer" asp-controller="LecturerGradeResults" asp-action="Index">Teaching Results</a>
                                </li>
                            }
                        }
                    </ul>
                    <ul class="navbar-nav">
                        @if (User.Identity?.IsAuthenticated == true)
                        {
                            <li class="nav-item">
                                <span class="nav-link text-dark">Hello, @User.Identity.Name</span>
                            </li>
                            <li class="nav-item">
                                <form asp-controller="Account" asp-action="Logout" method="post">
                                    @Html.AntiForgeryToken()
                                    <button type="submit" class="btn btn-link nav-link text-dark">Logout</button>
                                </form>
                            </li>
                        }
                        else
                        {
                            <li class="nav-item">
                                <a class="nav-link text-dark" asp-controller="Account" asp-action="Login">Login</a>
                            </li>
                        }
                    </ul>
                </div>
            </div>
        </nav>
    </header>
    <div class="container">
        <main role="main" class="pb-3">
            @RenderBody()
        </main>
    </div>

    <footer class="border-top footer text-muted">
        <div class="container">
            &copy; 2026 - UniAcademic.Web - <a asp-area="" asp-controller="Home" asp-action="Privacy">Privacy</a>
        </div>
    </footer>
    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
