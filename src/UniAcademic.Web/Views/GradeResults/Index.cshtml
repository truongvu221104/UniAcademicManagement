@using Microsoft.AspNetCore.Authorization
@using Microsoft.AspNetCore.Mvc.Rendering
@using UniAcademic.Application.Security
@inject IAuthorizationService AuthorizationService
@model IReadOnlyCollection<UniAcademic.Application.Models.GradeResults.GradeResultListItemModel>

@{
    ViewData["Title"] = "Grade Results";
    var courseOfferingOptions = ViewBag.CourseOfferingOptions as IReadOnlyCollection<SelectListItem> ?? Array.Empty<SelectListItem>();
    var canCalculate = (await AuthorizationService.AuthorizeAsync(User, PermissionConstants.BuildPolicy(PermissionConstants.GradeResults.Calculate))).Succeeded;
}

<h1 class="h3 mb-3">Grade Results</h1>

@if (TempData["ErrorMessage"] is string errorMessage)
{
    <div class="alert alert-danger">@errorMessage</div>
}

<form method="get" class="row g-3 mb-3">
    <div class="col-md-6">
        <label class="form-label">Course Offering</label>
        <select name="courseOfferingId" class="form-select">
            @foreach (var option in courseOfferingOptions)
            {
                <option value="@option.Value" selected="@option.Selected">@option.Text</option>
            }
        </select>
    </div>
    <div class="col-md-6 d-flex align-items-end gap-2">
        <button type="submit" class="btn btn-primary">Filter</button>
        @if (canCalculate)
        {
            <a asp-action="Calculate" class="btn btn-success">Calculate Results</a>
        }
    </div>
</form>

<table class="table table-striped">
    <thead>
        <tr>
            <th>Student</th>
            <th>Course Offering</th>
            <th>Final Score</th>
            <th>Passing Score</th>
            <th>Passed</th>
            <th>Calculated</th>
            <th></th>
        </tr>
    </thead>
    <tbody>
    @foreach (var item in Model)
    {
        <tr>
            <td>@item.StudentCode - @item.StudentFullName</td>
            <td>@item.CourseOfferingCode</td>
            <td>@item.WeightedFinalScore.ToString("0.00")</td>
            <td>@item.PassingScore.ToString("0.00")</td>
            <td>@(item.IsPassed ? "Pass" : "Fail")</td>
            <td>@item.CalculatedAtUtc.ToString("yyyy-MM-dd HH:mm")</td>
            <td class="text-end">
                <a asp-action="Details" asp-route-id="@item.Id" class="btn btn-sm btn-outline-primary">Details</a>
            </td>
        </tr>
    }
    </tbody>
</table>
