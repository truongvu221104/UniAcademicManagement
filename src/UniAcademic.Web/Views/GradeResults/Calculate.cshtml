@using Microsoft.AspNetCore.Mvc.Rendering
@model UniAcademic.Web.Models.GradeResults.CalculateGradeResultsViewModel

@{
    ViewData["Title"] = "Calculate Grade Results";
    var courseOfferingOptions = ViewBag.CourseOfferingOptions as IReadOnlyCollection<SelectListItem> ?? Array.Empty<SelectListItem>();
}

<h1 class="h3 mb-3">Calculate Grade Results</h1>

<form method="post">
    @Html.AntiForgeryToken()
    <div asp-validation-summary="ModelOnly" class="text-danger"></div>
    <div class="mb-3">
        <label asp-for="CourseOfferingId" class="form-label"></label>
        <select asp-for="CourseOfferingId" class="form-select">
            @foreach (var option in courseOfferingOptions)
            {
                <option value="@option.Value" selected="@option.Selected">@option.Text</option>
            }
        </select>
        <span asp-validation-for="CourseOfferingId" class="text-danger"></span>
    </div>
    <div class="mb-3">
        <label asp-for="PassingScore" class="form-label"></label>
        <input asp-for="PassingScore" class="form-control" />
        <span asp-validation-for="PassingScore" class="text-danger"></span>
    </div>
    <button type="submit" class="btn btn-primary">Calculate</button>
    <a asp-action="Index" class="btn btn-secondary">Cancel</a>
</form>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
