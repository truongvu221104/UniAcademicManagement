@model UniAcademic.Application.Models.CourseOfferings.CourseOfferingModel

@{
    ViewData["Title"] = "Course Offering Details";
}

<h1 class="h3 mb-3">Course Offering Details</h1>

<dl class="row">
    <dt class="col-sm-3">Code</dt>
    <dd class="col-sm-9">@Model.Code</dd>

    <dt class="col-sm-3">Display Name</dt>
    <dd class="col-sm-9">@Model.DisplayName</dd>

    <dt class="col-sm-3">Course</dt>
    <dd class="col-sm-9">@Model.CourseCode - @Model.CourseName</dd>

    <dt class="col-sm-3">Semester</dt>
    <dd class="col-sm-9">@Model.SemesterCode - @Model.SemesterName</dd>

    <dt class="col-sm-3">Capacity</dt>
    <dd class="col-sm-9">@Model.Capacity</dd>

    <dt class="col-sm-3">Status</dt>
    <dd class="col-sm-9">@Model.Status</dd>

    <dt class="col-sm-3">Description</dt>
    <dd class="col-sm-9">@Model.Description</dd>
</dl>

<a asp-action="Edit" asp-route-id="@Model.Id" class="btn btn-primary">Edit</a>
<a asp-controller="CourseOfferingRosters" asp-action="Details" asp-route-courseOfferingId="@Model.Id" class="btn btn-outline-info">Roster</a>
<a asp-controller="CourseOfferingRosters" asp-action="Finalize" asp-route-courseOfferingId="@Model.Id" class="btn btn-outline-warning">Finalize Roster</a>
<a asp-action="Index" class="btn btn-secondary">Back</a>
