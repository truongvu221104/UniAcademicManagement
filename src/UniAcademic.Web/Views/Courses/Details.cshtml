@model UniAcademic.Application.Models.Courses.CourseModel

@{
    ViewData["Title"] = "Course Details";
}

<div class="d-flex justify-content-between align-items-center mb-3">
    <h1 class="h3 mb-0">Course Details</h1>
    <div>
        <a asp-action="Edit" asp-route-id="@Model.Id" class="btn btn-primary">Edit</a>
        <a asp-action="Index" class="btn btn-secondary">Back</a>
    </div>
</div>

<dl class="row">
    <dt class="col-sm-2">Code</dt>
    <dd class="col-sm-10">@Model.Code</dd>

    <dt class="col-sm-2">Name</dt>
    <dd class="col-sm-10">@Model.Name</dd>

    <dt class="col-sm-2">Credits</dt>
    <dd class="col-sm-10">@Model.Credits</dd>

    <dt class="col-sm-2">Faculty</dt>
    <dd class="col-sm-10">
        @if (string.IsNullOrWhiteSpace(Model.FacultyName))
        {
            @:-
        }
        else
        {
            @($"{Model.FacultyCode} - {Model.FacultyName}")
        }
    </dd>

    <dt class="col-sm-2">Status</dt>
    <dd class="col-sm-10">@Model.Status</dd>

    <dt class="col-sm-2">Description</dt>
    <dd class="col-sm-10">@Model.Description</dd>
</dl>
