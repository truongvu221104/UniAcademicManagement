@using Microsoft.AspNetCore.Mvc.Rendering
@model IReadOnlyCollection<UniAcademic.Application.Models.LecturerProfiles.LecturerProfileListItemModel>

@{
    ViewData["Title"] = "Lecturer Profiles";
    var keyword = ViewBag.Keyword as string;
    var facultyOptions = ViewBag.FacultyOptions as IReadOnlyCollection<SelectListItem> ?? Array.Empty<SelectListItem>();
}

<div class="d-flex justify-content-between align-items-center mb-3">
    <h1 class="h3 mb-0">Lecturer Profiles</h1>
    <a asp-action="Create" class="btn btn-primary">Create Lecturer Profile</a>
</div>

<form method="get" class="row g-3 mb-3">
    <div class="col-md-4">
        <label class="form-label">Keyword</label>
        <input type="text" name="keyword" value="@keyword" class="form-control" />
    </div>
    <div class="col-md-4">
        <label class="form-label">Faculty</label>
        <select name="facultyId" class="form-select">
            @foreach (var option in facultyOptions)
            {
                <option value="@option.Value" selected="@option.Selected">@option.Text</option>
            }
        </select>
    </div>
    <div class="col-md-3">
        <label class="form-label">Active</label>
        <select name="isActive" class="form-select">
            <option value="">All</option>
            <option value="true" selected="@(ViewBag.IsActive is true)">Active</option>
            <option value="false" selected="@(ViewBag.IsActive is false)">Inactive</option>
        </select>
    </div>
    <div class="col-md-1 d-flex align-items-end">
        <button type="submit" class="btn btn-secondary w-100">Filter</button>
    </div>
</form>

<table class="table table-striped">
    <thead>
        <tr>
            <th>Code</th>
            <th>Full Name</th>
            <th>Faculty</th>
            <th>Email</th>
            <th>Phone</th>
            <th>Active</th>
            <th class="text-end">Actions</th>
        </tr>
    </thead>
    <tbody>
    @foreach (var item in Model)
    {
        <tr>
            <td>@item.Code</td>
            <td>@item.FullName</td>
            <td>@item.FacultyName</td>
            <td>@item.Email</td>
            <td>@item.PhoneNumber</td>
            <td>@item.IsActive</td>
            <td class="text-end">
                <a asp-action="Details" asp-route-id="@item.Id" class="btn btn-sm btn-outline-info">Details</a>
                <a asp-action="Edit" asp-route-id="@item.Id" class="btn btn-sm btn-outline-primary">Edit</a>
                <form asp-action="Delete" asp-route-id="@item.Id" method="post" class="d-inline">
                    @Html.AntiForgeryToken()
                    <button type="submit" class="btn btn-sm btn-outline-danger" onclick="return confirm('Delete this lecturer profile?');">Delete</button>
                </form>
            </td>
        </tr>
    }
    </tbody>
</table>
