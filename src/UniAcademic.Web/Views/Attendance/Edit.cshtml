@using UniAcademic.Domain.Enums
@model UniAcademic.Web.Models.Attendance.UpdateAttendanceRecordsViewModel

@{
    ViewData["Title"] = "Edit Attendance";
}

<h1 class="h3 mb-3">Edit Attendance Records</h1>

<div class="mb-3">
    <strong>@Model.CourseOfferingCode</strong> - @Model.CourseName (@Model.SemesterName)<br />
    Session @Model.SessionNo on @Model.SessionDate.ToString("yyyy-MM-dd")
</div>

<form method="post">
    @Html.AntiForgeryToken()
    <input asp-for="Id" type="hidden" />
    <input asp-for="CourseOfferingId" type="hidden" />
    <input asp-for="CourseOfferingCode" type="hidden" />
    <input asp-for="CourseName" type="hidden" />
    <input asp-for="SemesterName" type="hidden" />
    <input asp-for="SessionDate" type="hidden" />
    <input asp-for="SessionNo" type="hidden" />
    <input asp-for="Title" type="hidden" />
    <input asp-for="Note" type="hidden" />
    <div asp-validation-summary="ModelOnly" class="text-danger"></div>

    <table class="table table-bordered table-striped">
        <thead>
            <tr>
                <th>Student Code</th>
                <th>Full Name</th>
                <th>Student Class</th>
                <th>Status</th>
                <th>Note</th>
            </tr>
        </thead>
        <tbody>
        @for (var i = 0; i < Model.Records.Count; i++)
        {
            <tr>
                <td>
                    @Model.Records[i].StudentCode
                    <input asp-for="Records[@i].RosterItemId" type="hidden" />
                    <input asp-for="Records[@i].StudentCode" type="hidden" />
                    <input asp-for="Records[@i].StudentFullName" type="hidden" />
                    <input asp-for="Records[@i].StudentClassName" type="hidden" />
                </td>
                <td>@Model.Records[i].StudentFullName</td>
                <td>@Model.Records[i].StudentClassName</td>
                <td>
                    <select asp-for="Records[@i].Status" class="form-select" asp-items="Html.GetEnumSelectList<AttendanceStatus>()"></select>
                </td>
                <td>
                    <input asp-for="Records[@i].Note" class="form-control" />
                    <span asp-validation-for="Records[@i].Note" class="text-danger"></span>
                </td>
            </tr>
        }
        </tbody>
    </table>

    <button type="submit" class="btn btn-primary">Save</button>
    <a asp-action="Details" asp-route-id="@Model.Id" class="btn btn-secondary">Cancel</a>
</form>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
