@using UniAcademic.Application.Models.Semesters
@using UniAcademic.Domain.Enums
@model IReadOnlyCollection<SemesterListItemModel>

@{
    ViewData["Title"] = "Semesters";
    var keyword = ViewBag.Keyword as string;
    var academicYear = ViewBag.AcademicYear as string;
    var termNo = ViewBag.TermNo as int?;
    var selectedStatus = ViewBag.Status as SemesterStatus?;
}

<div class="d-flex justify-content-between align-items-center mb-3">
    <h1 class="h3 mb-0">Semesters</h1>
    <a asp-action="Create" class="btn btn-primary">Create Semester</a>
</div>

@if (TempData["ErrorMessage"] is string errorMessage)
{
    <div class="alert alert-danger">@errorMessage</div>
}

<form method="get" class="row g-3 mb-3">
    <div class="col-md-4">
        <input type="text" name="keyword" value="@keyword" class="form-control" placeholder="Search by code, name or academic year" />
    </div>
    <div class="col-md-2">
        <input type="text" name="academicYear" value="@academicYear" class="form-control" placeholder="Academic year" />
    </div>
    <div class="col-md-2">
        <input type="number" name="termNo" value="@termNo" min="1" max="3" class="form-control" placeholder="Term no" />
    </div>
    <div class="col-md-2">
        <select name="status" class="form-select">
            <option value="">All statuses</option>
            @foreach (var status in Enum.GetValues<SemesterStatus>())
            {
                <option value="@status" selected="@(selectedStatus == status)">@status</option>
            }
        </select>
    </div>
    <div class="col-md-2">
        <button type="submit" class="btn btn-outline-primary">Search</button>
        <a asp-action="Index" class="btn btn-outline-secondary">Reset</a>
    </div>
</form>

<table class="table table-striped">
    <thead>
        <tr>
            <th>Code</th>
            <th>Name</th>
            <th>Academic Year</th>
            <th>Term</th>
            <th>Start Date</th>
            <th>End Date</th>
            <th>Status</th>
            <th class="text-end">Actions</th>
        </tr>
    </thead>
    <tbody>
    @if (Model.Count == 0)
    {
        <tr>
            <td colspan="8" class="text-center">No semesters found.</td>
        </tr>
    }
    else
    {
        @foreach (var semester in Model)
        {
            <tr>
                <td>@semester.Code</td>
                <td>@semester.Name</td>
                <td>@semester.AcademicYear</td>
                <td>@semester.TermNo</td>
                <td>@semester.StartDate.ToString("yyyy-MM-dd")</td>
                <td>@semester.EndDate.ToString("yyyy-MM-dd")</td>
                <td>@semester.Status</td>
                <td class="text-end">
                    <a asp-action="Details" asp-route-id="@semester.Id" class="btn btn-sm btn-outline-secondary">Details</a>
                    <a asp-action="Edit" asp-route-id="@semester.Id" class="btn btn-sm btn-outline-primary">Edit</a>
                    <form asp-action="Delete" asp-route-id="@semester.Id" method="post" class="d-inline">
                        @Html.AntiForgeryToken()
                        <button type="submit" class="btn btn-sm btn-outline-danger" onclick="return confirm('Delete this semester?');">Delete</button>
                    </form>
                </td>
            </tr>
        }
    }
    </tbody>
</table>
