@using Microsoft.AspNetCore.Mvc.Rendering
@model UniAcademic.Web.Models.Enrollments.CreateEnrollmentViewModel

@{
    ViewData["Title"] = "Enroll Student";
    var studentProfileOptions = ViewBag.StudentProfileOptions as IReadOnlyCollection<SelectListItem> ?? Array.Empty<SelectListItem>();
    var courseOfferingOptions = ViewBag.CourseOfferingOptions as IReadOnlyCollection<SelectListItem> ?? Array.Empty<SelectListItem>();
}

<h1 class="h3 mb-3">Enroll Student</h1>

<form method="post">
    @Html.AntiForgeryToken()
    <div asp-validation-summary="ModelOnly" class="text-danger"></div>
    <div class="mb-3">
        <label asp-for="StudentProfileId" class="form-label"></label>
        <select asp-for="StudentProfileId" class="form-select">
            @foreach (var option in studentProfileOptions)
            {
                <option value="@option.Value" selected="@option.Selected">@option.Text</option>
            }
        </select>
        <span asp-validation-for="StudentProfileId" class="text-danger"></span>
    </div>
    <div class="mb-3">
        <label asp-for="CourseOfferingId" class="form-label"></label>
        <select asp-for="CourseOfferingId" class="form-select">
            @foreach (var option in courseOfferingOptions)
            {
                <option value="@option.Value" selected="@option.Selected">@option.Text</option>
            }
        </select>
        <span asp-validation-for="CourseOfferingId" class="text-danger"></span>
    </div>
    <div class="mb-3">
        <label asp-for="Note" class="form-label"></label>
        <textarea asp-for="Note" class="form-control" rows="4"></textarea>
        <span asp-validation-for="Note" class="text-danger"></span>
    </div>
    <button type="submit" class="btn btn-primary">Enroll</button>
    <a asp-action="Index" class="btn btn-secondary">Cancel</a>
</form>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
