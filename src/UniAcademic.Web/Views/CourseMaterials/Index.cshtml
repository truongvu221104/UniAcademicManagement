@using Microsoft.AspNetCore.Authorization
@using Microsoft.AspNetCore.Mvc.Rendering
@using UniAcademic.Application.Security
@inject IAuthorizationService AuthorizationService
@model IReadOnlyCollection<UniAcademic.Application.Models.Materials.CourseMaterialListItemModel>

@{
    ViewData["Title"] = "Course Materials";
    var courseOfferingOptions = ViewBag.CourseOfferingOptions as IReadOnlyCollection<SelectListItem> ?? Array.Empty<SelectListItem>();
    var canCreate = (await AuthorizationService.AuthorizeAsync(User, PermissionConstants.BuildPolicy(PermissionConstants.CourseMaterials.Create))).Succeeded;
    var canDownload = (await AuthorizationService.AuthorizeAsync(User, PermissionConstants.BuildPolicy(PermissionConstants.CourseMaterials.Download))).Succeeded;
}

<h1 class="h3 mb-3">Course Materials</h1>

@if (TempData["ErrorMessage"] is string errorMessage)
{
    <div class="alert alert-danger">@errorMessage</div>
}

<form method="get" class="row g-3 mb-3">
    <div class="col-md-6">
        <label class="form-label">Course Offering</label>
        <select name="courseOfferingId" class="form-select">
            @foreach (var option in courseOfferingOptions)
            {
                <option value="@option.Value" selected="@option.Selected">@option.Text</option>
            }
        </select>
    </div>
    <div class="col-md-6 d-flex align-items-end gap-2">
        <button type="submit" class="btn btn-primary">Filter</button>
        @if (canCreate)
        {
            <a asp-action="Create" class="btn btn-success">Upload Material</a>
        }
    </div>
</form>

<table class="table table-striped">
    <thead>
        <tr>
            <th>Title</th>
            <th>Course Offering</th>
            <th>Type</th>
            <th>File</th>
            <th>Published</th>
            <th>Uploaded</th>
            <th></th>
        </tr>
    </thead>
    <tbody>
    @foreach (var item in Model)
    {
        <tr>
            <td>@item.Title</td>
            <td>@item.CourseOfferingCode</td>
            <td>@item.MaterialType</td>
            <td>@item.OriginalFileName</td>
            <td>@(item.IsPublished ? "Yes" : "No")</td>
            <td>@item.UploadedAtUtc.ToString("yyyy-MM-dd HH:mm")</td>
            <td class="text-end">
                <a asp-action="Details" asp-route-id="@item.Id" class="btn btn-sm btn-outline-primary">Details</a>
                @if (canDownload)
                {
                    <a asp-action="Download" asp-route-id="@item.Id" class="btn btn-sm btn-outline-secondary">Download</a>
                }
            </td>
        </tr>
    }
    </tbody>
</table>
