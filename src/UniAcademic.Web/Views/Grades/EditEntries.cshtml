@model UniAcademic.Web.Models.Grades.UpdateGradeEntriesViewModel

@{
    ViewData["Title"] = "Edit Grade Entries";
}

<h1 class="h3 mb-3">Edit Grade Entries</h1>

<div class="mb-3">
    <strong>@Model.CourseOfferingCode</strong> - @Model.CourseName (@Model.SemesterName)<br />
    Category: @Model.Name | Max Score: @Model.MaxScore | Weight: @Model.Weight
</div>

<form method="post">
    @Html.AntiForgeryToken()
    <input asp-for="Id" type="hidden" />
    <input asp-for="CourseOfferingCode" type="hidden" />
    <input asp-for="CourseName" type="hidden" />
    <input asp-for="SemesterName" type="hidden" />
    <input asp-for="Name" type="hidden" />
    <input asp-for="Weight" type="hidden" />
    <input asp-for="MaxScore" type="hidden" />
    <div asp-validation-summary="ModelOnly" class="text-danger"></div>

    <table class="table table-bordered table-striped">
        <thead>
            <tr>
                <th>Student Code</th>
                <th>Full Name</th>
                <th>Student Class</th>
                <th>Score</th>
                <th>Note</th>
            </tr>
        </thead>
        <tbody>
        @for (var i = 0; i < Model.Entries.Count; i++)
        {
            <tr>
                <td>
                    @Model.Entries[i].StudentCode
                    <input asp-for="Entries[i].RosterItemId" type="hidden" />
                    <input asp-for="Entries[i].StudentCode" type="hidden" />
                    <input asp-for="Entries[i].StudentFullName" type="hidden" />
                    <input asp-for="Entries[i].StudentClassName" type="hidden" />
                </td>
                <td>@Model.Entries[i].StudentFullName</td>
                <td>@Model.Entries[i].StudentClassName</td>
                <td>
                    <input asp-for="Entries[i].Score" class="form-control" />
                    <span asp-validation-for="Entries[i].Score" class="text-danger"></span>
                </td>
                <td>
                    <input asp-for="Entries[i].Note" class="form-control" />
                    <span asp-validation-for="Entries[i].Note" class="text-danger"></span>
                </td>
            </tr>
        }
        </tbody>
    </table>

    <button type="submit" class="btn btn-primary">Save</button>
    <a asp-action="Details" asp-route-id="@Model.Id" class="btn btn-secondary">Cancel</a>
</form>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
