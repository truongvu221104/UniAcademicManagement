@using Microsoft.AspNetCore.Mvc.Rendering
@model UniAcademic.Web.Models.Grades.CreateGradeCategoryViewModel

@{
    ViewData["Title"] = "Create Grade Category";
    var courseOfferingOptions = ViewBag.CourseOfferingOptions as IReadOnlyCollection<SelectListItem> ?? Array.Empty<SelectListItem>();
}

<h1 class="h3 mb-3">Create Grade Category</h1>

<form method="post">
    @Html.AntiForgeryToken()
    <div asp-validation-summary="ModelOnly" class="text-danger"></div>
    <div class="mb-3">
        <label asp-for="CourseOfferingId" class="form-label"></label>
        <select asp-for="CourseOfferingId" class="form-select">
            @foreach (var option in courseOfferingOptions)
            {
                <option value="@option.Value" selected="@option.Selected">@option.Text</option>
            }
        </select>
        <span asp-validation-for="CourseOfferingId" class="text-danger"></span>
    </div>
    <div class="mb-3">
        <label asp-for="Name" class="form-label"></label>
        <input asp-for="Name" class="form-control" />
        <span asp-validation-for="Name" class="text-danger"></span>
    </div>
    <div class="row">
        <div class="col-md-4 mb-3">
            <label asp-for="Weight" class="form-label"></label>
            <input asp-for="Weight" class="form-control" />
            <span asp-validation-for="Weight" class="text-danger"></span>
        </div>
        <div class="col-md-4 mb-3">
            <label asp-for="MaxScore" class="form-label"></label>
            <input asp-for="MaxScore" class="form-control" />
            <span asp-validation-for="MaxScore" class="text-danger"></span>
        </div>
        <div class="col-md-4 mb-3">
            <label asp-for="OrderIndex" class="form-label"></label>
            <input asp-for="OrderIndex" class="form-control" />
            <span asp-validation-for="OrderIndex" class="text-danger"></span>
        </div>
    </div>
    <div class="form-check mb-3">
        <input asp-for="IsActive" class="form-check-input" />
        <label asp-for="IsActive" class="form-check-label"></label>
    </div>
    <button type="submit" class="btn btn-primary">Create</button>
    <a asp-action="Index" class="btn btn-secondary">Cancel</a>
</form>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
