@model UniAcademic.Web.Models.Grades.UpdateGradeEntriesViewModel

@{
    ViewData["Title"] = "Edit Grade Entries";
}

<h1 class="h3 mb-3">Edit Grade Entries</h1>

<div class="mb-3">
    <strong>@Model.CourseOfferingCode</strong> - @Model.CourseName (@Model.SemesterName)<br />
    Category: @Model.Name | Max Score: @Model.MaxScore | Weight: @Model.Weight
</div>

<div class="alert alert-light border">
    Update student scores for this grade item. The <strong>Score</strong> column is numeric. The <strong>Note</strong> column is free-text for grading comments, feedback, or context.
</div>

<form method="post">
    @Html.AntiForgeryToken()
    <input asp-for="Id" type="hidden" />
    <input asp-for="CourseOfferingCode" type="hidden" />
    <input asp-for="CourseName" type="hidden" />
    <input asp-for="SemesterName" type="hidden" />
    <input asp-for="Name" type="hidden" />
    <input asp-for="Weight" type="hidden" />
    <input asp-for="MaxScore" type="hidden" />
    <div asp-validation-summary="ModelOnly" class="text-danger"></div>

    <div class="table-responsive mb-3">
    <table class="table table-bordered table-striped align-middle">
        <thead>
            <tr>
                <th>Student Code</th>
                <th>Full Name</th>
                <th>Class</th>
                <th>Score</th>
                <th>Grading Note</th>
            </tr>
        </thead>
        <tbody>
        @for (var i = 0; i < Model.Entries.Count; i++)
        {
            <tr>
                <td>
                    @Model.Entries[i].StudentCode
                    <input asp-for="Entries[i].RosterItemId" type="hidden" />
                    <input asp-for="Entries[i].StudentCode" type="hidden" />
                    <input asp-for="Entries[i].StudentFullName" type="hidden" />
                    <input asp-for="Entries[i].StudentClassName" type="hidden" />
                </td>
                <td>@Model.Entries[i].StudentFullName</td>
                <td>@Model.Entries[i].StudentClassName</td>
                <td style="min-width: 180px;">
                    <input asp-for="Entries[i].Score" class="form-control" type="number" step="0.01" min="0" max="@Model.MaxScore" />
                </td>
                <td style="min-width: 260px;">
                    <textarea asp-for="Entries[i].Note" class="form-control" rows="2" placeholder="Optional grading note"></textarea>
                </td>
            </tr>
        }
        </tbody>
    </table>
    </div>

    <button type="submit" class="btn btn-primary">Save</button>
    <a asp-action="Details" asp-route-id="@Model.Id" class="btn btn-secondary">Cancel</a>
</form>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
