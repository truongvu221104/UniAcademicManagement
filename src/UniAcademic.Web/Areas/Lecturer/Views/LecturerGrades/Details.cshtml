@model UniAcademic.Application.Models.Grades.GradeCategoryModel

@{
    ViewData["Title"] = "Grade Category Details";
    var isGradebookEditable = ViewBag.IsGradebookEditable as bool? ?? false;
}

<h1 class="h3 mb-3">Grade Category Details</h1>

<div class="mb-3">
    <strong>@Model.CourseOfferingCode</strong> - @Model.CourseName (@Model.SemesterName)<br />
    Category: @Model.Name | Weight: @Model.Weight | Max Score: @Model.MaxScore
</div>

<div class="alert @(isGradebookEditable ? "alert-info" : "alert-secondary")">
    Grade item structure is managed by academic staff.
    @if (isGradebookEditable)
    {
        <span> This class is still open, so you can update each student's score and note through <strong>Edit Student Scores</strong>.</span>
    }
    else
    {
        <span> Final results already exist for this class, so this page is now review-only for lecturers.</span>
    }
</div>

<table class="table table-striped align-middle">
    <thead>
        <tr>
            <th>Student Code</th>
            <th>Full Name</th>
            <th>Class</th>
            <th>Score</th>
            <th>Note</th>
        </tr>
    </thead>
    <tbody>
    @foreach (var item in Model.Entries)
    {
        <tr>
            <td>@item.StudentCode</td>
            <td>@item.StudentFullName</td>
            <td>@item.StudentClassName</td>
            <td>@item.Score</td>
            <td>@item.Note</td>
        </tr>
    }
    </tbody>
</table>

@if (isGradebookEditable)
{
    <a asp-action="EditEntries" asp-route-id="@Model.Id" class="btn btn-success">Edit Student Scores</a>
}
<a asp-action="Categories" asp-route-courseOfferingId="@Model.CourseOfferingId" class="btn btn-secondary">Back</a>
