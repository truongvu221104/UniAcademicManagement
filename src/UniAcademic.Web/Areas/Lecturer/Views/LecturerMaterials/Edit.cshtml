@model UniAcademic.Web.Models.Materials.UpdateCourseMaterialViewModel

@{
    ViewData["Title"] = "Edit Material";
}

<h1 class="h3 mb-3">Edit Material</h1>

<form method="post">
    @Html.AntiForgeryToken()
    <input asp-for="Id" type="hidden" />
    <input asp-for="CourseOfferingId" type="hidden" />
    <input asp-for="CourseOfferingCode" type="hidden" />
    <input asp-for="CourseName" type="hidden" />
    <input asp-for="SemesterName" type="hidden" />
    <input asp-for="OriginalFileName" type="hidden" />
    <input asp-for="ContentType" type="hidden" />
    <input asp-for="SizeInBytes" type="hidden" />
    <input asp-for="IsPublished" type="hidden" />
    <div asp-validation-summary="ModelOnly" class="text-danger"></div>
    <div class="row g-3">
        <div class="col-md-6">
            <label asp-for="Title" class="form-label"></label>
            <input asp-for="Title" class="form-control" />
        </div>
        <div class="col-md-3">
            <label asp-for="MaterialType" class="form-label"></label>
            <select asp-for="MaterialType" class="form-select" asp-items="Html.GetEnumSelectList<UniAcademic.Domain.Enums.CourseMaterialType>()"></select>
        </div>
        <div class="col-md-3">
            <label asp-for="SortOrder" class="form-label"></label>
            <input asp-for="SortOrder" class="form-control" />
        </div>
        <div class="col-12">
            <label asp-for="Description" class="form-label"></label>
            <textarea asp-for="Description" class="form-control" rows="3"></textarea>
        </div>
    </div>
    <div class="mt-3">
        <button type="submit" class="btn btn-primary">Save</button>
        <button type="submit" formaction="@Url.Action("SetPublishState", "LecturerMaterials", new { area = "Lecturer", id = Model.Id, isPublished = !Model.IsPublished })" class="btn btn-warning">
            @(Model.IsPublished ? "Unpublish" : "Publish")
        </button>
        <a asp-action="Details" asp-route-id="@Model.Id" class="btn btn-secondary">Cancel</a>
    </div>
</form>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
