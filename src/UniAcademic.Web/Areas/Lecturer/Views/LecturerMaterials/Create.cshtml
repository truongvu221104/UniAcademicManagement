@model UniAcademic.Web.Models.Materials.UploadCourseMaterialViewModel

@{
    ViewData["Title"] = "Upload Material";
}

<h1 class="h3 mb-3">Upload Material</h1>

<form method="post" enctype="multipart/form-data">
    @Html.AntiForgeryToken()
    <div asp-validation-summary="ModelOnly" class="text-danger"></div>
    <div class="row g-3">
        <div class="col-md-4">
            <label asp-for="CourseOfferingId" class="form-label">Course Offering</label>
            <select asp-for="CourseOfferingId" class="form-select" asp-items="ViewBag.CourseOfferingOptions"></select>
        </div>
        <div class="col-md-4">
            <label asp-for="Title" class="form-label"></label>
            <input asp-for="Title" class="form-control" />
        </div>
        <div class="col-md-4">
            <label asp-for="MaterialType" class="form-label"></label>
            <select asp-for="MaterialType" class="form-select" asp-items="Html.GetEnumSelectList<UniAcademic.Domain.Enums.CourseMaterialType>()"></select>
        </div>
        <div class="col-md-3">
            <label asp-for="SortOrder" class="form-label"></label>
            <input asp-for="SortOrder" class="form-control" />
        </div>
        <div class="col-md-3 d-flex align-items-end">
            <div class="form-check">
                <input asp-for="IsPublished" class="form-check-input" />
                <label asp-for="IsPublished" class="form-check-label"></label>
            </div>
        </div>
        <div class="col-md-6">
            <label asp-for="File" class="form-label"></label>
            <input asp-for="File" class="form-control" />
        </div>
        <div class="col-12">
            <label asp-for="Description" class="form-label"></label>
            <textarea asp-for="Description" class="form-control" rows="3"></textarea>
        </div>
    </div>
    <div class="mt-3">
        <button type="submit" class="btn btn-primary">Upload</button>
        <a asp-action="Index" class="btn btn-secondary">Cancel</a>
    </div>
</form>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
