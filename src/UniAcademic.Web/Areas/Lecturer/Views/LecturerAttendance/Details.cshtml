@model UniAcademic.Application.Models.Attendance.AttendanceSessionModel

@{
    ViewData["Title"] = "Attendance Details";
}

<h1 class="h3 mb-3">Attendance Details</h1>

<div class="mb-3">
    <strong>@Model.CourseOfferingCode</strong> - @Model.CourseName (@Model.SemesterName)<br />
    Session: @Model.SessionDate.ToString("yyyy-MM-dd") / #@Model.SessionNo / @Model.Title
</div>

@if (!string.IsNullOrWhiteSpace(Model.Note))
{
    <div class="alert alert-light border">
        <strong>Session note:</strong> @Model.Note
    </div>
}

<div class="alert alert-info">
    Review the session here first. Use <strong>Edit Session and Records</strong> if you need to change the session title, the session note, the session number, or each student's attendance status.
</div>

<table class="table table-striped align-middle">
    <thead>
        <tr>
            <th>Student Code</th>
            <th>Full Name</th>
            <th>Class</th>
            <th>Status</th>
            <th>Note</th>
        </tr>
    </thead>
    <tbody>
    @foreach (var item in Model.Records)
    {
        <tr>
            <td>@item.StudentCode</td>
            <td>@item.StudentFullName</td>
            <td>@item.StudentClassName</td>
            <td>@item.Status</td>
            <td>@item.Note</td>
        </tr>
    }
    </tbody>
</table>

<a asp-action="Edit" asp-route-id="@Model.Id" class="btn btn-primary">Edit Session and Records</a>
<a asp-action="Sessions" asp-route-courseOfferingId="@Model.CourseOfferingId" class="btn btn-secondary">Back</a>
