@model UniAcademic.Application.Models.Attendance.AttendanceSessionModel

@{
    ViewData["Title"] = "Attendance Details";
}

<h1 class="h3 mb-3">Attendance Details</h1>

<div class="mb-3">
    <strong>@Model.CourseOfferingCode</strong> - @Model.CourseName (@Model.SemesterName)<br />
    Session: @Model.SessionDate.ToString("yyyy-MM-dd") / #@Model.SessionNo / @Model.Title
</div>

<table class="table table-striped">
    <thead>
        <tr>
            <th>Student Code</th>
            <th>Full Name</th>
            <th>Class</th>
            <th>Status</th>
            <th>Note</th>
        </tr>
    </thead>
    <tbody>
    @foreach (var item in Model.Records)
    {
        <tr>
            <td>@item.StudentCode</td>
            <td>@item.StudentFullName</td>
            <td>@item.StudentClassName</td>
            <td>@item.Status</td>
            <td>@item.Note</td>
        </tr>
    }
    </tbody>
</table>

<a asp-action="Edit" asp-route-id="@Model.Id" class="btn btn-primary">Edit</a>
<a asp-action="Index" class="btn btn-secondary">Back</a>
