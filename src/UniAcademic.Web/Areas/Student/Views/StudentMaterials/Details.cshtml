@model UniAcademic.Web.Models.StudentPortal.StudentMaterialDetailsViewModel

@{
    ViewData["Title"] = "Material Details";
}

<div class="d-flex justify-content-between align-items-center mb-3">
    <div>
        <h1 class="h3 mb-1">@Model.CourseOfferingCode</h1>
        <p class="text-muted mb-0">@Model.CourseName (@Model.SemesterName)</p>
    </div>
    <a asp-action="Index" class="btn btn-outline-secondary">Back to Materials</a>
</div>

@if (Model.Materials.Count == 0)
{
    <div class="alert alert-info">No published materials have been uploaded for this course offering yet.</div>
}
else
{
    <p class="text-muted">Only materials published for this enrolled course offering are shown below.</p>
    <div class="table-responsive">
        <table class="table table-striped align-middle">
            <thead>
                <tr>
                    <th>Title</th>
                    <th>Type</th>
                    <th>File</th>
                    <th>Uploaded At</th>
                    <th>Status</th>
                    <th class="text-end">Actions</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var item in Model.Materials)
                {
                    <tr>
                        <td class="fw-semibold">@item.Title</td>
                        <td>@item.MaterialType</td>
                        <td>
                            <div>@item.OriginalFileName</div>
                            <div class="text-muted small">@((item.SizeInBytes / 1024d / 1024d).ToString("0.0")) MB</div>
                        </td>
                        <td>@item.UploadedAtUtc.ToString("yyyy-MM-dd HH:mm")</td>
                        <td>
                            @if (item.IsPublished)
                            {
                                <span class="badge bg-success">Published</span>
                            }
                            else
                            {
                                <span class="badge bg-secondary">Draft</span>
                            }
                        </td>
                        <td class="text-end">
                            <a asp-area="Student" asp-controller="StudentMaterials" asp-action="Download" asp-route-id="@item.Id" class="btn btn-sm btn-outline-primary">Download</a>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
}
