@model IReadOnlyCollection<UniAcademic.Web.Models.StudentPortal.StudentMaterialsOverviewItemViewModel>

@{
    ViewData["Title"] = "My Materials";
    var keyword = ViewBag.Keyword as string;
}

<div class="d-flex justify-content-between align-items-center mb-3">
    <div>
        <h1 class="h3 mb-1">My Materials</h1>
        <p class="text-muted mb-0">Only course offerings that you have enrolled in can expose materials to your account.</p>
    </div>
</div>

<form method="get" class="row g-2 mb-3">
    <div class="col-md-6">
        <input type="text" name="keyword" value="@keyword" class="form-control" placeholder="Search by offering code or course name" />
    </div>
    <div class="col-auto">
        <button type="submit" class="btn btn-primary">Filter</button>
    </div>
    <div class="col-auto">
        <a asp-action="Index" class="btn btn-outline-secondary">Reset</a>
    </div>
</form>

@if (Model.Count == 0)
{
    <div class="alert alert-info">No enrolled course offerings are available for this account yet.</div>
}
else
{
    <div class="table-responsive">
        <table class="table table-striped align-middle">
            <thead>
                <tr>
                    <th>Course Offering</th>
                    <th>Semester</th>
                    <th>Published Materials</th>
                    <th>Latest Upload</th>
                    <th class="text-end">Action</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var item in Model)
                {
                    <tr>
                        <td>
                            <div class="fw-semibold">@item.CourseOfferingCode</div>
                            <div class="text-muted small">@item.CourseName</div>
                        </td>
                        <td>@item.SemesterName</td>
                        <td><span class="badge bg-success">@item.MaterialCount</span></td>
                        <td>@(item.LatestUploadedAtUtc.HasValue ? item.LatestUploadedAtUtc.Value.ToString("yyyy-MM-dd HH:mm") : "No materials yet")</td>
                        <td class="text-end">
                            <a asp-action="Details" asp-route-courseOfferingId="@item.CourseOfferingId" class="btn btn-sm btn-outline-primary">View Materials</a>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
}
