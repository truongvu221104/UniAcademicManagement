@model IReadOnlyCollection<UniAcademic.Web.Models.StudentPortal.StudentGradeOverviewItemViewModel>

@{
    ViewData["Title"] = "My Grades & Results";
    var keyword = ViewBag.Keyword as string;
}

<div class="d-flex justify-content-between align-items-center mb-3">
    <div>
        <h1 class="h3 mb-1">My Grades &amp; Results</h1>
        <p class="text-muted mb-0">Choose a subject to review grade components and, when available, the final calculated result for that course offering.</p>
    </div>
</div>

<form method="get" class="row g-2 mb-3">
    <div class="col-md-6">
        <input type="text" name="keyword" value="@keyword" class="form-control" placeholder="Search by offering code or course name" />
    </div>
    <div class="col-auto">
        <button type="submit" class="btn btn-primary">Filter</button>
    </div>
    <div class="col-auto">
        <a asp-action="Index" class="btn btn-outline-secondary">Reset</a>
    </div>
</form>

@if (Model.Count == 0)
{
    <div class="alert alert-info">No grade-enabled course offerings are available for this account yet.</div>
}
else
{
    <div class="table-responsive">
        <table class="table table-striped align-middle">
            <thead>
                <tr>
                    <th>Course Offering</th>
                    <th>Semester</th>
                    <th>Grade Items</th>
                    <th>Scored</th>
                    <th>Pending</th>
                    <th>Average Score</th>
                    <th>Final Result</th>
                    <th class="text-end">Action</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var item in Model)
                {
                    <tr>
                        <td>
                            <div class="fw-semibold">@item.CourseOfferingCode</div>
                            <div class="text-muted small">@item.CourseName</div>
                        </td>
                        <td>@item.SemesterName</td>
                        <td>@item.GradeItemCount</td>
                        <td><span class="badge bg-success">@item.ScoredItemCount</span></td>
                        <td><span class="badge bg-secondary">@item.PendingItemCount</span></td>
                        <td class="fw-semibold">@(item.ScoredItemCount == 0 ? "Pending" : item.AverageScore.ToString("0.00"))</td>
                        <td>
                            @if (item.IsPassed.HasValue)
                            {
                                <div class="fw-semibold">@item.FinalScore?.ToString("0.00")</div>
                                <span class="badge @(item.IsPassed.Value ? "bg-success" : "bg-danger")">
                                    @(item.IsPassed.Value ? "Passed" : "Not Passed")
                                </span>
                            }
                            else
                            {
                                <span class="badge bg-secondary">Pending</span>
                            }
                        </td>
                        <td class="text-end">
                            <a asp-action="Details" asp-route-courseOfferingId="@item.CourseOfferingId" class="btn btn-sm btn-outline-primary">View Grades</a>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
}
