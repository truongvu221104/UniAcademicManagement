<UserControl x:Class="UniAcademic.AdminApp.Views.LoginView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d">
    <Border Padding="32"
            MaxWidth="420"
            Background="White"
            CornerRadius="12"
            BorderBrush="#D0D7DE"
            BorderThickness="1">
        <StackPanel>
            <TextBlock Text="UniAcademic Admin"
                       FontSize="24"
                       FontWeight="SemiBold" />
            <TextBlock Text="Internal operations console"
                       Margin="0,4,0,24"
                       Foreground="#57606A" />

            <TextBlock Text="Username or Email" />
            <TextBox Margin="0,6,0,12"
                     Text="{Binding UserNameOrEmail, UpdateSourceTrigger=PropertyChanged}" />

            <TextBlock Text="Password" />
            <PasswordBox x:Name="PasswordBox"
                         Margin="0,6,0,12"
                         PasswordChanged="PasswordBox_OnPasswordChanged" />

            <CheckBox Content="Remember me"
                      Margin="0,0,0,12"
                      IsChecked="{Binding RememberMe}" />

            <TextBlock Text="{Binding ErrorMessage}"
                       Foreground="#C62828"
                       TextWrapping="Wrap"
                       Margin="0,0,0,12" />

            <Button Content="Login"
                    Height="36"
                    Command="{Binding LoginCommand}" />
        </StackPanel>
    </Border>
</UserControl>
