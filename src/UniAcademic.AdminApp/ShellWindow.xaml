<Window x:Class="UniAcademic.AdminApp.ShellWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="UniAcademic Admin"
        Width="1480"
        Height="900"
        WindowStartupLocation="CenterScreen">
    <Window.Resources>
        <Style x:Key="SidebarNavButtonStyle" TargetType="Button">
            <Setter Property="Margin" Value="0,0,0,8" />
            <Setter Property="Padding" Value="14,10" />
            <Setter Property="HorizontalContentAlignment" Value="Left" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="Foreground" Value="#D7E2F0" />
            <Setter Property="BorderBrush" Value="Transparent" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="NavBorder"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="12">
                            <ContentPresenter Margin="{TemplateBinding Padding}"
                                              HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                              VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="NavBorder" Property="Background" Value="#182B49" />
                                <Setter Property="Foreground" Value="White" />
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="NavBorder" Property="Opacity" Value="0.92" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <DataTrigger Binding="{Binding IsSelected}" Value="True">
                    <Setter Property="Background" Value="#E7F0FE" />
                    <Setter Property="Foreground" Value="#123B7B" />
                    <Setter Property="BorderBrush" Value="#B8CEF3" />
                </DataTrigger>
            </Style.Triggers>
        </Style>
    </Window.Resources>

    <Grid Background="#EEF3F8">
        <Grid Visibility="{Binding IsAuthenticated, Converter={StaticResource BooleanToVisibilityConverter}}">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="300" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0"
                    Margin="16"
                    Background="#0F1D33"
                    Padding="18"
                    CornerRadius="18">
                <DockPanel>
                    <StackPanel DockPanel.Dock="Bottom">
                        <Border Padding="14"
                                Margin="0,12,0,12"
                                Background="#152643"
                                CornerRadius="14"
                                BorderBrush="#223756"
                                BorderThickness="1">
                            <StackPanel>
                                <TextBlock Text="Signed in as"
                                           Foreground="#8DA7C6"
                                           FontSize="12" />
                                <TextBlock Text="{Binding CurrentUserDisplay}"
                                           Foreground="White"
                                           FontSize="14"
                                           FontWeight="SemiBold"
                                           TextWrapping="Wrap"
                                           Margin="0,4,0,4" />
                                <TextBlock Text="{Binding CurrentUserRoleSummary}"
                                           Foreground="#C5D4E8"
                                           TextWrapping="Wrap" />
                            </StackPanel>
                        </Border>
                        <Button Content="Logout"
                                Command="{Binding LogoutCommand}"
                                Background="#1D4ED8"
                                BorderBrush="#1D4ED8" />
                    </StackPanel>

                    <ScrollViewer VerticalScrollBarVisibility="Auto">
                        <StackPanel>
                            <Border Background="#152643"
                                    CornerRadius="16"
                                    Padding="16"
                                    Margin="0,0,0,18">
                                <StackPanel>
                                    <TextBlock Text="UniAcademic"
                                               Foreground="White"
                                               FontSize="24"
                                               FontWeight="Bold" />
                                    <TextBlock Text="Admin Workspace"
                                               Foreground="#9FB6D2"
                                               Margin="0,4,0,0" />
                                    <TextBlock Text="Internal academic operations console"
                                               Foreground="#C5D4E8"
                                               TextWrapping="Wrap"
                                               Margin="0,10,0,0" />
                                </StackPanel>
                            </Border>

                            <ItemsControl ItemsSource="{Binding Groups}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <StackPanel Margin="0,0,0,16">
                                            <TextBlock Text="{Binding Title}"
                                                       Foreground="#8DA7C6"
                                                       FontSize="12"
                                                       FontWeight="SemiBold"
                                                       Margin="4,0,0,10"
                                                       TextWrapping="Wrap" />
                                            <ItemsControl ItemsSource="{Binding Items}">
                                                <ItemsControl.ItemTemplate>
                                                    <DataTemplate>
                                                        <Button Content="{Binding Title}"
                                                                Style="{StaticResource SidebarNavButtonStyle}"
                                                                Command="{Binding OpenCommand}" />
                                                    </DataTemplate>
                                                </ItemsControl.ItemTemplate>
                                            </ItemsControl>
                                        </StackPanel>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </StackPanel>
                    </ScrollViewer>
                </DockPanel>
            </Border>

            <Grid Grid.Column="1" Margin="0,16,16,16">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>

                <Border Grid.Row="0"
                        Padding="18"
                        Background="White"
                        CornerRadius="18"
                        BorderBrush="#D6DEE8"
                        BorderThickness="1">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>

                        <StackPanel>
                            <TextBlock Text="{Binding CurrentSectionTitle}"
                                       Foreground="#64748B"
                                       FontSize="12"
                                       FontWeight="SemiBold" />
                            <TextBlock Text="{Binding CurrentModuleTitle}"
                                       Foreground="#18324A"
                                       FontSize="28"
                                       FontWeight="Bold"
                                       Margin="0,6,0,0" />
                        </StackPanel>

                        <Border Grid.Column="1"
                                Padding="14,10"
                                Background="#F5F8FC"
                                BorderBrush="#D6DEE8"
                                BorderThickness="1"
                                CornerRadius="14">
                            <StackPanel>
                                <TextBlock Text="Workspace"
                                           Foreground="#64748B"
                                           FontSize="12" />
                                <TextBlock Text="AdminApp"
                                           Foreground="#18324A"
                                           FontWeight="SemiBold" />
                            </StackPanel>
                        </Border>
                    </Grid>
                </Border>

                <Border Grid.Row="1"
                        Margin="0,16,0,0"
                        Padding="6"
                        Background="White"
                        CornerRadius="18"
                        BorderBrush="#D6DEE8"
                        BorderThickness="1">
                    <ContentControl Content="{Binding CurrentModule}" />
                </Border>
            </Grid>
        </Grid>

        <ContentControl Content="{Binding Login}"
                        HorizontalAlignment="Center"
                        VerticalAlignment="Center">
            <ContentControl.Style>
                <Style TargetType="ContentControl">
                    <Setter Property="Visibility" Value="Visible" />
                    <Style.Triggers>
                        <DataTrigger Binding="{Binding IsAuthenticated}" Value="True">
                            <Setter Property="Visibility" Value="Collapsed" />
                        </DataTrigger>
                    </Style.Triggers>
                </Style>
            </ContentControl.Style>
        </ContentControl>
    </Grid>
</Window>
